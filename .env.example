# Токен від @BotFather
BOT_TOKEN=your_telegram_bot_token

# ID адміністраторів (через кому). Дізнатися: напишіть боту @userinfobot
ADMIN_CHAT_IDS=123456789

# Нагадування за N годин до візиту (за замовчуванням 24)
REMINDER_HOURS_BEFORE=24

# Опційно: Google Calendar + Meet (див. README)
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Шлях до JSON ключа сервісного акаунта Google
GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json
